# "vertex_endpoint" = call a deployed Vertex AI Endpoint (production)
# "local_tf"        = run TensorFlow in-process (needs requirements-dev.txt)
INFERENCE_SOURCE=vertex_endpoint

GCP_PROJECT=406789890946
GCP_REGION=us-central1
VERTEX_ENDPOINT_ID=

# "local" = read scaler.json / recent_days.csv from app/data/
# "gcs"   = download from GCS_BUCKET at startup
DATA_SOURCE=local

GCS_BUCKET=solarix
GCS_SCALER_BLOB=models/lstm/latest/scaler.json
GCS_RECENT_DAYS_BLOB=data/recent_days.csv

# Needed whenever DATA_SOURCE=gcs or INFERENCE_SOURCE=vertex_endpoint, unless
# you're already using `gcloud auth application-default login` locally.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

FACILITY_NAME=당진 태양광 3호기
FACILITY_CAPACITY_MW=1.0

CORS_ORIGINS=["http://localhost:5173"]
